{
    "name": "@woopsocial/n8n-nodes-woopsocial",
    "version": "0.1.8",
    "description": "n8n community node for WoopSocial social media publishing workflows.",
    "license": "MIT",
    "homepage": "https://github.com/WoopSocial/n8n-nodes-woopsocial",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "WoopSocial",
        "email": "contact@woopsocial.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/WoopSocial/n8n-nodes-woopsocial.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/WoopSocialApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/WoopSocial/WoopSocial.node.js",
            "dist/nodes/WoopSocialPostPublishedTrigger/WoopSocialPostPublishedTrigger.node.js",
            "dist/nodes/WoopSocialPostFailedTrigger/WoopSocialPostFailedTrigger.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "^0.23.1",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "^2.13.1"
    }
}
